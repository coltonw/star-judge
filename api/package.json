{
  "name": "api",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --env local",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute star-judge-db --file=src/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute star-judge-db --local --file=src/db/schema.sql",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@star-judge/shared": "workspace:*",
    "@star-judge/voting": "workspace:*",
    "hono": "^4.12.14",
    "jose": "^6.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@cloudflare/workers-types": "^4.20250409.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.11.0"
  }
}
